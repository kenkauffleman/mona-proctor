{
  "name": "mona-proctor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GCLOUD_PROJECT=demo-mona-proctor tsx watch backend/index.ts",
    "backend:dev": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GCLOUD_PROJECT=demo-mona-proctor tsx watch backend/index.ts",
    "backend:api:exercise": "tsx scripts/exerciseHistoryApi.ts",
    "backend:api:validate": "firebase emulators:exec --only firestore \"tsx scripts/historyRoundTripValidate.ts\"",
    "backend:build": "tsc -p tsconfig.backend.json",
    "backend:container:build": "docker build -f backend/Dockerfile -t mona-proctor-backend-validation .",
    "backend:container:run": "docker run --rm --add-host host.docker.internal:host-gateway -p 8081:8081 -e PORT=8081 -e GCLOUD_PROJECT=demo-mona-proctor -e FIRESTORE_EMULATOR_HOST=host.docker.internal:8080 mona-proctor-backend-validation",
    "backend:container:validate": "firebase emulators:exec --only firestore \"tsx scripts/backendContainerHistoryValidate.ts\"",
    "emulator:firestore": "firebase emulators:start --only firestore",
    "emulator:firestore:check": "firebase emulators:exec --only firestore \"tsx scripts/firestoreEmulatorSanityCheck.ts\"",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
    "emulator:firestore:manualcheck": "tsx scripts/firestoreEmulatorManualCheck.ts",
    "wave7:validate": "firebase emulators:exec --only firestore \"tsx scripts/historyRoundTripValidate.ts\"",
    "wave7:manual": "tsx scripts/manualWave7Stack.ts",
    "deploy": "bash scripts/deploy/manage.sh",
    "deploy:firestore:check": "bash scripts/deploy/firestore-check-prereqs.sh",
    "deploy:firestore:init": "bash scripts/deploy/firestore-init.sh",
    "deploy:firestore:validate": "bash scripts/deploy/firestore-validate.sh",
    "deploy:firestore:plan": "bash scripts/deploy/firestore-plan.sh",
    "deploy:firestore:apply": "bash scripts/deploy/firestore-apply.sh",
    "deploy:firestore:config-check": "tsx scripts/checkFirestoreTerraformConfig.ts",
    "deploy:cloudrun:check": "bash scripts/deploy/cloudrun-check-prereqs.sh",
    "deploy:cloudrun:init": "bash scripts/deploy/cloudrun-init.sh",
    "deploy:cloudrun:build": "bash scripts/deploy/cloudrun-build.sh",
    "deploy:cloudrun:validate": "bash scripts/deploy/cloudrun-validate.sh",
    "deploy:cloudrun:plan": "bash scripts/deploy/cloudrun-plan.sh",
    "deploy:cloudrun:apply": "bash scripts/deploy/cloudrun-apply.sh",
    "deploy:cloudrun:validation-commands": "bash scripts/deploy/cloudrun-print-validation-commands.sh",
    "deploy:cloudrun:validate-private": "bash scripts/deploy/cloudrun-validate-private.sh",
    "deploy:cloudrun:config-check": "tsx scripts/checkCloudRunTerraformConfig.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.5.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "firebase-tools": "^15.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
