{
  "name": "mona-proctor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "backend:dev": "tsx watch backend/index.ts",
    "backend:build": "tsc -p tsconfig.backend.json",
    "backend:container:build": "docker build -f backend/Dockerfile -t mona-proctor-backend-validation .",
    "backend:container:run": "docker run --rm --add-host host.docker.internal:host-gateway -p 8081:8081 -e PORT=8081 -e GCLOUD_PROJECT=demo-mona-proctor -e FIRESTORE_EMULATOR_HOST=host.docker.internal:8080 mona-proctor-backend-validation",
    "backend:container:validate": "firebase emulators:exec --only firestore \"tsx scripts/backendContainerValidate.ts\"",
    "emulator:firestore": "firebase emulators:start --only firestore",
    "emulator:firestore:check": "firebase emulators:exec --only firestore \"tsx scripts/firestoreEmulatorSanityCheck.ts\"",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
    "emulator:firestore:manualcheck": "tsx scripts/firestoreEmulatorManualCheck.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.5.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "firebase-tools": "^15.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
